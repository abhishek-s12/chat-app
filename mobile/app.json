{
  "expo": {
    "name": "ChatApp",
    "slug": "chatapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chatapp",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.abhisheks12.chatapp",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.abhisheks12.chatapp",
      "adaptiveIcon": {
        "backgroundColor": "#3478f6",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3478f6",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "ChatApp needs access to your photo library to send images in chats."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
